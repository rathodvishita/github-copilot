{
  "info": {
    "name": "Task Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Tasks",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:3000/tasks",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["tasks"]
        }
      }
    },
    {
      "name": "Create Task",
      "request": {
        "method": "POST",
        "url": {
          "raw": "http://localhost:3000/tasks",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["tasks"]
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Sample Task\",\n  \"description\": \"This is a sample task\",\n  \"status\": \"to_do\",\n  \"priority\": \"medium\",\n  \"due_date\": \"2026-02-25T00:00:00.000Z\"\n}"
        }
      }
    },
    {
      "name": "Get Task By ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:3000/tasks/{{taskId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["tasks", "{{taskId}}"]
        }
      }
    },
    {
      "name": "Update Task",
      "request": {
        "method": "PUT",
        "url": {
          "raw": "http://localhost:3000/tasks/{{taskId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["tasks", "{{taskId}}"]
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Updated Task\",\n  \"description\": \"Updated description\",\n  \"status\": \"in_progress\",\n  \"priority\": \"low\",\n  \"due_date\": \"2026-02-28T00:00:00.000Z\"\n}"
        }
      }
    },
    {
      "name": "Delete Task",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "http://localhost:3000/tasks/{{taskId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["tasks", "{{taskId}}"]
        }
      }
    }
  ]
}
